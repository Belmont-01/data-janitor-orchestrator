# =============================================================================
# SECRETS — Never commit these
# =============================================================================
.env
.env.*
*.env
secrets.py

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/
*.whl
.installed.cfg

# =============================================================================
# Virtual Environment
# =============================================================================
.venv/
venv/
ENV/
env/
.virtualenv

# =============================================================================
# Data files — raw inputs and outputs stay local
# =============================================================================
data/raw/*
data/clean/*
!data/raw/.gitkeep
!data/clean/.gitkeep

# =============================================================================
# VS Code
# =============================================================================
.vscode/
*.code-workspace

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Logs & temp files
# =============================================================================
*.log
*.tmp
*.temp
tmp/
temp/
